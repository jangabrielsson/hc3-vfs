{"name":"ListFuns2","type":"com.fibaro.binarySensor","apiVersion":"1.3","initialProperties":{"viewLayout":{"$jason":{"body":{"header":{"style":{"height":"0"},"title":"quickApp_device_54"},"sections":{"items":[{"components":[{"name":"label_ID_0","style":{"weight":"1.2"},"text":"Label (Title)","type":"label","visible":true},{"style":{"weight":"0.5"},"type":"space"}],"style":{"weight":"1.2"},"type":"vertical"},{"components":[{"name":"button_ID_1_1","style":{"weight":"1.2"},"text":"Btn","type":"button","visible":true},{"style":{"weight":"0.5"},"type":"space"}],"style":{"weight":"1.2"},"type":"vertical"}]}},"head":{"title":"quickApp_device_54"}}},"uiView":[{"components":[{"name":"label_ID_0","style":{"weight":"1.0"},"text":"Label (Title)","type":"label","visible":true}],"style":{"weight":"1.0"},"type":"horizontal"},{"components":[{"eventBinding":{"onLongPressDown":[{"params":{"actionName":"UIAction","args":["onLongPressDown","button_ID_1_1"]},"type":"deviceAction"}],"onLongPressReleased":[{"params":{"actionName":"UIAction","args":["onLongPressReleased","button_ID_1_1"]},"type":"deviceAction"}],"onReleased":[{"params":{"actionName":"UIAction","args":["onReleased","button_ID_1_1"]},"type":"deviceAction"}]},"name":"button_ID_1_1","style":{"weight":"1.0"},"text":"Btn","type":"button","visible":true}],"style":{"weight":"1.0"},"type":"horizontal"}],"useUiView":true,"uiCallbacks":[],"quickAppVariables":[],"typeTemplateInitialized":true,"userDescription":""},"initialInterfaces":[],"files":[{"name":"main","isMain":true,"isOpen":false,"content":"\nlocal function printEnv(p,t)\n  if type(t)=='table' and t ~= _G  then\n    for k,v in pairs(t) do \n       print(p,k,tostring(v))\n    end\n  else  \n     print(p,\"'\"..tostring(t)..\"'\")\n  end\nend\n\nQuickApp.logLevel = 9\n\nfunction  QuickApp:onInit()\n    self:debug(\"onInit\")\n    local a = QuickApp.logLevel\n    print(a)\n    --fibaro.homeCenter.systemService.reboot() ok\n    for k,v in pairs(_G) do\n       printEnv(k,v)  \n    end   \nend       \n-- Test"},{"name":"foo","isMain":false,"isOpen":false,"content":""}]}